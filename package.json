{
  "name": "oshilock",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "mobile": "pnpm --filter @oshilock/mobile start:ts",
    "mobile:clear": "pnpm --filter @oshilock/mobile start:ts -- --clear",
    "mobile:ios": "pnpm --filter @oshilock/mobile ios:dev",
    "api": "pnpm --filter @oshilock/be-api dev",
    "test": "turbo test",
    "test:all": "turbo test:all",
    "test:ut": "turbo test:ut",
    "test:db": "turbo test:db",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2",
    "prettier": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  },
  "packageManager": "pnpm@10.12.0+sha512.3ab6da6066b7b14d6e9609a31d780191484b8e85f8d0e4581ef333bf4d869799937f5e57cbb8d3da2023019f6d4869a9acc381457fcb1d86e15fc44bfd4eb6a4"
}
