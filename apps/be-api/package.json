{
  "name": "@oshilock/be-api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "lint": "tsc --noEmit",
    "test": "pnpm run test:all",
    "test:ut": "vitest run --exclude '**/*.db.test.ts' --exclude '**/*.ai.test.ts'",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:ai": "vitest run --include '**/*.ai.test.ts'",
    "test:all": "pnpm run test:ut && pnpm run test:db"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "catalog:",
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/client-sqs": "catalog:",
    "@aws-sdk/cloudfront-signer": "catalog:",
    "@aws-sdk/credential-providers": "catalog:",
    "@aws-sdk/lib-dynamodb": "catalog:",
    "@aws-sdk/s3-request-presigner": "catalog:",
    "@google/genai": "catalog:",
    "@hono/node-server": "catalog:",
    "@oshilock/shared": "workspace:*",
    "@toon-format/toon": "catalog:",
    "@types/turndown": "catalog:",
    "@vercel/functions": "catalog:",
    "cheerio": "catalog:",
    "electrodb": "catalog:",
    "firebase-admin": "catalog:",
    "hono": "catalog:",
    "turndown": "catalog:",
    "ulid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "dotenv": "^16",
    "testcontainers": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
